# ─── PRECISO Platform — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager — not .env files.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
SESSION_TIMEOUT_MINUTES=15

# ─── GoHighLevel (GHL) CRM ───────────────────────────────────────────────────
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-ghl-location-id
GHL_PIPELINE_ID=your-ghl-pipeline-id
GHL_WEBHOOK_SECRET=your-ghl-webhook-hmac-secret

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=preciso-documents
AWS_CLOUDWATCH_LOG_GROUP=/preciso/api

# ─── FirstSource (Kit Fulfillment) ────────────────────────────────────────────
FIRSTSOURCE_API_URL=https://api.firstsource.example.com
FIRSTSOURCE_API_KEY=placeholder-pending-docs
FIRSTSOURCE_WEBHOOK_SECRET=placeholder-pending-docs

# ─── Centogene (Lab Partner — primary) ───────────────────────────────────────
# GEPPADO ordering + Azure middleware webhooks. HMAC-SHA256 on every
# inbound payload; signature in X-Centogene-Signature header.
CENTOGENE_API_URL=https://api.centogene.example.com
CENTOGENE_API_KEY=placeholder-pending-docs
CENTOGENE_API_SECRET=placeholder-pending-docs
CENTOGENE_WEBHOOK_SECRET=placeholder-pending-docs
# URL Centogene exposes for inbound sample alerts (Step 5 — outbound from us
# to them when a specimen ships via FedEx).
CENTOGENE_INBOUND_ALERT_URL=https://api.centogene.example.com/alerts/sample-shipped

# ─── Cenegenics (legacy, deprecated) ─────────────────────────────────────────
# Retained so historical envs continue to deserialise. New deploys should
# use CENTOGENE_* above; these variables are read only as fallbacks and
# will be removed once all consumers migrate.
CENEGENICS_API_URL=https://api.cenegenics.example.com
CENEGENICS_API_KEY=placeholder-pending-docs
CENEGENICS_WEBHOOK_SECRET=placeholder-pending-docs

# ─── Sampled (Lab Partner — Pilot) ───────────────────────────────────────────
SAMPLED_API_URL=https://api.sampled.example.com
SAMPLED_API_KEY=placeholder-pending-docs
SAMPLED_WEBHOOK_SECRET=placeholder-pending-docs

# ─── VeriCense (Identity / Biometric SSO) ─────────────────────────────────────
VERICENSE_API_URL=https://api.vericense.example.com
VERICENSE_API_KEY=placeholder-pending-jj-team
VERICENSE_WEBHOOK_SECRET=placeholder-pending-jj-team

# ─── FedEx / 3PL Tracking ────────────────────────────────────────────────────
FEDEX_API_URL=https://apis.fedex.com
FEDEX_API_KEY=placeholder-pending-provisioning
FEDEX_WEBHOOK_SECRET=placeholder-pending-provisioning

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
# Provider pays per kit order via Stripe Payment Element.
# SECURITY: PHI is never sent to Stripe. Only provider email + amount +
# panel-type SKU + opaque order UUID cross the wire. See the type-enforced
# payload helper in apps/portal/src/lib/stripe/server.ts.
#
# For production HIPAA pilot: request a Stripe Healthcare BAA (Enterprise
# tier). Not strictly required because no PHI flows, but audit-friendly.
#
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Price IDs per panel type (create in Stripe Dashboard → Products).
# Fall back to a single STRIPE_PRICE_DEFAULT if these are unset.
STRIPE_PRICE_NEWBORN=price_your-newborn-panel-price-id
STRIPE_PRICE_PEDIATRIC=price_your-pediatric-panel-price-id
STRIPE_PRICE_ADULT=price_your-adult-panel-price-id
STRIPE_PRICE_SENIOR=price_your-senior-panel-price-id

# ─── Sentry (Error Tracking) ─────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
PORTAL_URL=http://localhost:3000
REPORT_PORTAL_URL=https://precisoreport.com

# Cross-tier links — provider portal renders an "Admin login" link that
# points at this URL. Set per environment (localhost in dev, the deployed
# admin Vercel URL in prod). Leaving unset falls back to localhost:3001.
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001/login
NEXT_PUBLIC_DEV_CONSOLE_URL=http://localhost:3002/login

# ─── System API Key (for machine-to-machine: barcode scanners, etc.) ──────────
SYSTEM_API_KEY=your-system-api-key-min-32-chars

# ─── GHL Workflow IDs ─────────────────────────────────────────────────────────
GHL_DELIVERY_WORKFLOW_ID=your-ghl-delivery-workflow-id

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Upstash Redis (shared rate limiter + failed-login lockout) ──────────────
# Two provisioning paths, both supported by the shared rate-limit helper:
#
# (A) Vercel Marketplace → Upstash integration (recommended)
#     https://vercel.com/integrations/upstash
#     The integration auto-injects env vars into every selected project.
#     Variable names it uses: UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
#     (or legacy KV_REST_API_URL / KV_REST_API_TOKEN). No manual copy/paste.
#
# (B) Manual setup — create a DB at https://console.upstash.com and copy
#     the REST URL + token from the "REST API" tab into these two vars:
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-rest-token
#
# Must be set in every deployed app (portal, admin, dev) so all instances
# share one counter. Without Upstash, the rate limiter falls back to
# per-process in-memory which is bypassable across Vercel serverless
# instances and is NOT safe for production.
